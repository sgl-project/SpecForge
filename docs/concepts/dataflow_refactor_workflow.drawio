        </mxCell>
        <mxCell id="train_py" value="train.py / CLI&#xa;Input: config, launch args&#xa;Output: runtime graph handle&#xa;API: specforge train --config&#xa;Deployment: in-process only" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="510" y="170" width="245" height="105" as="geometry"/>
        </mxCell>
        <mxCell id="runtime_launcher" value="RuntimeLauncher / ComponentFactory&#xa;Input: resolved config&#xa;Output: controller, workers, stores&#xa;API: build(), start(), stop()&#xa;Deployment: in-process only" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="805" y="170" width="245" height="105" as="geometry"/>
        </mxCell>

        <mxCell id="boundary_trainer" value="Trainer Boundary - actor candidate when trainer is separate from rollout or inference" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f7fbff;strokeColor=#6c8ebf;dashed=1;fontStyle=1;fontSize=13;verticalAlign=top;spacingTop=8;" vertex="1" parent="1">
